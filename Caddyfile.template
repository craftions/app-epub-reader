{
    auto_https off
    admin off
}

:${PORT} {
    root * /srv
    encode zstd gzip
    file_server

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output stdout
        level INFO
    }
}
